# Copy to frontend/.env.local and fill in your own Auth0 tenant's values.
# Auth0 dashboard: Applications > (your SPA) > Settings for domain/client ID,
# Applications > APIs for the audience -- must match backend/.env's AUTH0_AUDIENCE.

VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://your-api-identifier
VITE_API_BASE_URL=http://localhost:8080
