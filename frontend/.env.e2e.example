# Copy to frontend/.env.e2e and fill in a dedicated Auth0 test user's
# credentials -- see e2e/README.md. Never use a real account here.
#
# Quote the password: an unquoted # starts a comment in .env file syntax
# and silently truncates everything after it.

E2E_AUTH0_EMAIL=your-test-user@example.com
E2E_AUTH0_PASSWORD="your-password-here"
