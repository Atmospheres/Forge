{
  "name": "forge-frontend",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b",
    "preview": "vite preview",
    "prelint": "vite build --logLevel warn",
    "lint": "eslint .",
    "test": "vitest",
