# Copy to backend/.env and fill in your own Auth0 tenant's values.
# Auth0 dashboard: Applications > APIs for the audience, Applications > (your SPA) > Settings for the domain.

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# Optional, defaults to http://localhost:5173 (see application.yml). Comma-separated list of
# origins allowed to call this API -- set this to your deployed frontend's origin(s) in any
# real deployment, or the browser will get CORS errors.
# FORGE_CORS_ALLOWED_ORIGINS=https://app.example.com
